# ── Dependências ─────────────────────────────────────────────────────────────
node_modules/
package-lock.json

# ── Configuração local (contém suas credenciais reais) ────────────────────────
# Use js/config.example.js como template e crie o seu próprio js/config.js
# O config.js NÃO deve ser commitado se contiver chaves privadas (Admin SDK, etc.)
# Nota: as chaves Firebase web (apiKey, appId…) são publicas por design —
# a segurança vem das Firestore Rules. Veja os comentários em js/config.js.
js/config.js

